{
  "name": "webdesigner-core",
  "version": "1.1.0",
  "description": "Active Orchestrator Engine & MCP Server for WebDesigner",
  "main": "dist/cli/index.js",
  "bin": {
    "wd": "./dist/cli/index.js"
  },
  "type": "commonjs",
  "scripts": {
    "build": "tsc && npm run build:mcp",
    "build:mcp": "esbuild src/mcp/server.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/mcp/server.js",
    "verify": "node scripts/verify-package.mjs",
    "test:mcp": "node scripts/smoke-mcp.mjs",
    "start": "node dist/cli/index.js",
    "mcp": "node dist/mcp/server.js",
    "dev:cli": "tsx src/cli/index.ts",
    "dev:mcp": "tsx src/mcp/server.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^11.1.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "esbuild": "^0.25.0",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3"
  }
}
