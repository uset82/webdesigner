{
  "name": "@codex-avatar-studio/asset-pipeline",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "pnpm --workspace-root exec biome lint packages/asset-pipeline",
    "test": "pnpm --workspace-root exec vitest run packages/asset-pipeline"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "fast-xml-parser": "^5.9.3",
    "imagetracerjs": "1.2.6",
    "jimp": "0.14.0",
    "svgo": "^4.0.1"
  }
}
